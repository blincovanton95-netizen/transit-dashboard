# Переменные окружения для деплоя

# Локальная разработка — API проксируется через Vite (vite.config.js)
# VITE_API_URL не нужен

# Production (Vercel) — API проксируется через vercel.json rewrites
# VITE_API_URL не нужен (используется относительный /api)

# Standalone frontend (без Vercel proxy):
# VITE_API_URL=https://transit-dashboard-mock.onrender.com

# Mock backend (Render/Railway):
# PORT=3001
# VEHICLE_COUNT=250
